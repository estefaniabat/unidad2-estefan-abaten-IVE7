//Problema:Determinar si un numero
//Ingresado por el usuario es + o -
Algoritmo ejemploSiEntonces
	//Entradas
	Definir num Como Entero
	Escribir "dame un número entero cualquiera:"
	leer num
	//Proceso
	si (num>0) Entonces
		Escribir "soy un número POSITIVO"
		sino 
			Escribir "soy un número NEGATIVO"
	FinSi
	//Salidas
FinAlgoritmo
