Algoritmo notas
	Definir l Como Cadena
	Escribir 'Escriba una letra: 'Sin Saltar
	Leer l
	Según l Hacer
		'A', 'a':
			Escribir 'Excelente'
		'B', 'b':
			Escribir 'Bueno'
		'C', 'c':
			Escribir 'Irregular'
		'D', 'd':
			Escribir 'Deficiente'
		'F', 'f':
			Escribir 'Reprobado'
		De Otro Modo:
			Escribir 'Digite una letra valida'
	FinSegún
FinAlgoritmo
